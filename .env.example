VCENTER_HOST=vcenter.example.local
VCENTER_USER=administrator@vsphere.local
VCENTER_PASSWORD=change-me
VCENTER_VERIFY_SSL=false

# Segurança de escrita
ALLOW_VM_STORAGE_MOVE=true
READ_ONLY_MODE=true
WRITE_ADMIN_KEY=

# CORS (frontend local)
CORS_ALLOW_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,http://127.0.0.1:5501,http://localhost:5501
CORS_ALLOW_CREDENTIALS=false

# Guardrails de movimento
MOVE_MIN_FREE_HEADROOM_PCT=15
MOVE_MIN_VM_RESERVE_RATIO=0.10
MOVE_MAX_TARGET_USED_PCT=95
MOVE_MAX_CONCURRENT_PER_CLUSTER=2
